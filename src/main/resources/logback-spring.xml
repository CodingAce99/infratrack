<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        Console appender with MDC correlation id.
        %mdc{correlationId} emits the value stored under the "correlationId" MDC key.
        When no correlation id is present (e.g., scheduled tasks outside the filter),
        Logback renders an empty string for that token.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [correlationId=%mdc{correlationId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
